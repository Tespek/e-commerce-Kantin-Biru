APP_NAME=kantin_biru
APP_ENV=production
APP_KEY=                # Generate: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://nama-project-kamu.vercel.app

APP_LOCALE=id
APP_FALLBACK_LOCALE=id

LOG_CHANNEL=stderr
LOG_LEVEL=error

# Ganti dengan credential MySQL online (Railway/PlanetScale/Aiven)
DB_CONNECTION=mysql
DB_HOST=               # host dari Railway/PlanetScale
DB_PORT=3306
DB_DATABASE=           # nama database
DB_USERNAME=           # username
DB_PASSWORD=           # password

# Wajib pakai cookie/array di Vercel (bukan file/database)
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=true

CACHE_STORE=array

FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync

BROADCAST_CONNECTION=log
